{
  "name": "vue-capacitor-haptics",
  "version": "1.0.0",
  "description": "Vue composable and directives helpers for Capacitor Haptics",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest",
    "test:coverage": "vitest run --coverage && node ./scripts/update-coverage-badges.mjs"
  },
  "peerDependencies": {
    "@capacitor/core": "^8.0.0",
    "@capacitor/haptics": "^8.0.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@capacitor/core": "^8.0.0",
    "@capacitor/haptics": "^8.0.0",
    "@rollup/plugin-swc": "^0.4.0",
    "@swc/core": "^1.3.0",
    "@vitest/coverage-istanbul": "^4.0.18",
    "typescript": "~5.9.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.17",
    "vue": "^3.5.22"
  },
  "keywords": [
    "vue",
    "capacitor",
    "haptics"
  ],
  "author": "ZDS",
  "license": "MIT"
}
